DASHSCOPE_API_KEY=your_dashscope_api_key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DATABASE_URL=sqlite:///./storage/app.db
UPLOAD_DIR=./storage/uploads
VECTOR_DIR=./storage/chroma
ARTIFACT_DIR=./storage/artifacts
FRONTEND_ORIGIN=http://localhost:5173
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=your_qq_email@qq.com
EMAIL_SMTP_PASSWORD=your_qq_mail_authorization_code
EMAIL_FROM=your_qq_email@qq.com
EMAIL_USE_SSL=true
EMAIL_IMAP_HOST=imap.qq.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=your_qq_email@qq.com
EMAIL_IMAP_PASSWORD=your_qq_mail_authorization_code
EMAIL_MARK_READ_ON_FETCH=true
